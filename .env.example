# .env.example — copy to .env and fill in values

BOT_TOKEN=         # токен от @BotFather (обязательно)
ADMIN_IDS=         # telegram user_id через запятую: 123456,789012 (обязательно)
ALLOWED_USERS=     # все разрешённые user_id включая админов (обязательно)

REPORT_TIME=09:00  # время авторассылки по умолчанию (HH:MM UTC)
TIMEZONE=Europe/Moscow  # часовой пояс по умолчанию для новых пользователей

MAX_FILE_SIZE_MB=10     # максимальный размер загружаемого .xlsx
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

DATABASE_PATH=data/reports.db  # путь к SQLite базе данных
HEALTH_PORT=8080               # порт FastAPI /health эндпоинта
